# Mantle Sepolia RPC (chain id 5003). Public RPC works but is rate-limited;
# use a paid provider (Alchemy, BlockPI, dRPC) for production.
PONDER_RPC_URL_5003=https://rpc.sepolia.mantle.xyz

# (Optional) Postgres database URL. If not provided, PGlite (embedded) is used.
DATABASE_URL=

# (Optional) Postgres schema name. Required if multiple Ponder instances share the same DB.
DATABASE_SCHEMA=

# ─── Contract addresses (fill after `forge script Deploy.s.sol` on Mantle Sepolia) ───
AGENT_REGISTRY_ADDRESS=
SQUADIUM_ADDRESS=
LIQUID_REPUTATION_ADDRESS=
REWARD_DISTRIBUTOR_ADDRESS=
SORTINO_ORACLE_ADDRESS=

# First block to index from (the deployment block). Avoid scanning the full chain.
START_BLOCK=0

# ─── Off-chain oracle signer (used by the Sortino calculation worker, not by Ponder core) ───
ORACLE_SIGNER_KEY=

# ─── External services (used by the Sortino worker / enrichment pipeline) ───
PYTH_HERMES_URL=https://hermes.pyth.network
NANSEN_API_KEY=
