# Mantle Sepolia RPC (chain id 5003). Public RPC works but is rate-limited;
# use a paid provider (Alchemy, BlockPI, dRPC) for production.
PONDER_RPC_URL_5003=https://rpc.sepolia.mantle.xyz

# (Optional) Postgres database URL. If not provided, PGlite (embedded) is used.
DATABASE_URL=

# (Optional) Postgres schema name. Required if multiple Ponder instances share the same DB.
DATABASE_SCHEMA=public

# ─── Squadium · Mantle Sepolia deployment (2026-05-19) ───
# Source: contracts/deployments.md
AGENT_REGISTRY_ADDRESS=0x5C8061694C8c1b4A2aB39762754D9a0DC549fBB1
SQUADIUM_ADDRESS=0x4299b716F33Be7F43D0Ebf0c1F4863D3fC4b37ec
LIQUID_REPUTATION_ADDRESS=0xE633d2bBb9D610A3dA777a651C1497257a159557
REWARD_DISTRIBUTOR_ADDRESS=0x2E4567125B73eEdA6b6B276a7ea7a9a4bd44aC22
AGENT_REPUTATION_ORACLE_ADDRESS=0x6a9aff1F4352648b39De2771A1Ed3f0F85E9D764

# First block to index from (deploy block of the first contract). Avoid scanning the full chain.
START_BLOCK=38879885

# ─── CCRI service: off-chain signer that pushes reputation on-chain ───
# Must match the `signer` configured in AgentReputationOracle at deploy time.
# (On the live deploy above, signer == deployer == 0x118594…D45d.)
ORACLE_SIGNER_KEY=

# ─── External services (CCRI feature enrichment) ───
PYTH_HERMES_URL=https://hermes.pyth.network
NANSEN_API_KEY=
